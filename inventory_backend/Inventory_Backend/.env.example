# MongoDB Atlas Connection
# Get your connection string from MongoDB Atlas dashboard
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&authSource=admin

# JWT Secret for authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here

# Cloudinary Configuration (for file uploads)
# Sign up at https://cloudinary.com and get your credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS Origins (comma-separated list of allowed frontend URLs)
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000
